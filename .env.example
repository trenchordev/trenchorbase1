# Environment Variables for Tax Auto-Scan System

# Vercel Cron Security (Önerilir - Production'da mutlaka kullan!)
CRON_SECRET=your_random_secure_secret_here_12345

# RPC Endpoints (Infura önerilir - daha hızlı ve güvenilir)
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
INFURA_API_KEY=your_infura_api_key_here
NEXT_PUBLIC_INFURA_API_KEY=your_infura_api_key_here

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Admin Authentication
ADMIN_PASSWORD=your_secure_admin_password
